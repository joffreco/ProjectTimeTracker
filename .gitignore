# ---------------------------------------------------------------------------
# .gitignore for ProjectTimeTracker (.NET 9 WinForms)
# ---------------------------------------------------------------------------

# ---- Build output ---------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
artifacts/
publish/
*.binlog

# ---- Visual Studio / Rider / VS Code -------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.userosscache
*.sln.docstates
*.DotSettings.user
*.csproj.user

# ---- Rider / ReSharper ----------------------------------------------------
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings
!*.sln.DotSettings

# ---- NuGet ----------------------------------------------------------------
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
project.lock.json
project.fragment.lock.json
.nuget/

# ---- Test results / coverage ---------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# ---- Debug / profiling ----------------------------------------------------
*.pdb
*.dbg
*.cache
*.pidb
*.svclog
*.psess
*.vsp
*.vspx
*.sap

# ---- OS files -------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# ---- Secrets / credentials -----------------------------------------------
# Keep the README explaining how to add the secret, ignore everything else.
Secrets/*
!Secrets/README.md
*.pfx
*.snk
appsettings.*.local.json
secrets.json

# ---- Local app data dumps (if ever copied into repo) ---------------------
event-queue.json
device.id

# ---- Misc -----------------------------------------------------------------
*.swp
*.bak
*.tmp
*.log
